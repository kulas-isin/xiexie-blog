---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} - 寫寫</title>
  <meta name="description" content="寫寫 - 走走停停，慢慢走，慢慢寫">
  <meta property="og:site_name" content="寫寫">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://xie-xie.netlify.app">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --color-bg: #faf8f3;
      --color-text: #3d3d3d;
      --color-text-light: #6b6b6b;
      --color-accent-brown: #c9a876;
      --color-accent-green: #8fb89f;
      --color-border: #e8e4dc;
      --color-hover: #f5f1e8;
      --font-display: 'Georgia', 'Garamond', serif;
      --font-body: 'Segoe UI', 'Helvetica Neue', sans-serif;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background-color: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      line-height: 1.6;
      letter-spacing: 0.3px;
    }

    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--color-accent-brown), transparent);
      z-index: 1000;
    }

    header {
      padding: 3rem 2rem;
      text-align: center;
      border-bottom: 1px solid var(--color-border);
      background: linear-gradient(135deg, rgba(200, 168, 118, 0.03), rgba(143, 184, 159, 0.03));
    }

    .header-content {
      max-width: 800px;
      margin: 0 auto;
    }

    h1 {
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 400;
      color: var(--color-text);
      margin-bottom: 0.5rem;
      letter-spacing: 0.05em;
    }

    .tagline {
      font-size: 1rem;
      color: var(--color-text-light);
      font-style: italic;
      letter-spacing: 0.15em;
      font-family: var(--font-display);
    }

    .container {
      max-width: 700px;
      margin: 0 auto;
      padding: 3rem 2rem;
    }

    footer {
      text-align: center;
      padding: 2rem;
      color: var(--color-text-light);
      font-size: 0.85rem;
      border-top: 1px solid var(--color-border);
      margin-top: 3rem;
      background: linear-gradient(135deg, rgba(200, 168, 118, 0.02), rgba(143, 184, 159, 0.02));
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 2.5rem;
      }

      .container {
        padding: 2rem 1.5rem;
      }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-content">
      <h1>寫寫</h1>
      <p class="tagline">走走停停，慢慢走，慢慢寫</p>
    </div>
  </header>

  <div class="container">
    <slot />
  </div>

  <footer>
    <p>© 2026 寫寫 | 走走停停，慢慢走，慢慢寫</p>
  </footer>
</body>
</html>
